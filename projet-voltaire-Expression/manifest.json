{
  "manifest_version": 3,
  "name": "Voltaire Helper Pro",
  "version": "1.3",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:1234/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://particuliers.projet-voltaire.fr/*"],
      "js": ["content.js"]
    }
  ]
}